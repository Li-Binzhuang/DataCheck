{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${fileDirname}",
      "python": "/Library/Frameworks/Python.framework/Versions/3.15/bin/python3",
      "args": [],
      "stopOnEntry": false,
      "justMyCode": true
    },
    {
      "name": "Python: Current File (External Terminal)",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "externalTerminal",
      "cwd": "${fileDirname}",
      "python": "/Library/Frameworks/Python.framework/Versions/3.15/bin/python3"
    }
  ]
}